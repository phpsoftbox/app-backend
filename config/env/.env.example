APP_ENV=dev
APP_DEBUG=1
APP_URL=https://domain.local
APP_KEY=
APP_INFLECTOR_LANG=en

APP_DB_MAIN_DSN="mariadb://app:app@mariadb:3306/app"
APP_DB_SEARCH_DSN="postgres://app:app@postgres:5432/app"
APP_DB_MIGRATIONS_BASE="database/migrations"

APP_STORAGE_DISK=local
APP_STORAGE_URL=/storage

VITE_DEV_SERVER=https://vite.domain.local
VITE_SSR_URL=
VITE_SSR_ENTRY=resources/js/ssr.tsx
VITE_SSR_TIMEOUT=2.0
INERTIA_VERSION=
INERTIA_SSR=1

APP_SESSION_NAME=psb_session
APP_SESSION_LIFETIME=0
APP_SESSION_PATH=/
APP_SESSION_DOMAIN=
APP_SESSION_SECURE=always
APP_SESSION_HTTP_ONLY=1
APP_SESSION_SAME_SITE=Lax
APP_SESSION_STRICT=1
APP_SESSION_ONLY_COOKIES=1
APP_SESSION_COOKIES=1
APP_SESSION_GC_MAX_LIFETIME=

TEST_DB_CONNECTIONS=default
TEST_DB_RELOAD=0
TEST_DB_RELOAD_MODE=dump
TEST_DB_SUFFIX=_autotests
TEST_DB_KEEP_DUMPS=0
